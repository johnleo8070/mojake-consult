{
    "redirects": [
        {
            "source": "/cpanel",
            "destination": "https://cpanel.mojakeconsult.com/",
            "permanent": true
        },
        {
            "source": "/webmail",
            "destination": "https://webmail.mojakeconsult.com/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}